# Copy to .env and fill in. Do NOT commit .env.
# `deploy.sh --bootstrap-env` will replace every `=change-me` with `openssl rand -hex 32`.

# ---- Public domain & TLS ----
# DNS A/AAAA must point at this host. Caddy will auto-issue TLS via Let's Encrypt.
VAULT_RAG_DOMAIN=vault.example.com
VAULT_RAG_ACME_EMAIL=admin@example.com

# ---- Postgres superuser ----
VAULT_RAG_PG_USER=postgres
VAULT_RAG_PG_PASSWORD=change-me

# ---- API tokens (Bearer headers) ----
VAULT_RAG_API_TOKEN=change-me
VAULT_RAG_MCP_TOKEN=change-me
# vt-0124: separate token for fleet's mutating + RCE-capable endpoints
# (workflow CRUD, /fleet/exec, /fleet/dispatch, /fleet/hosts/*/file).
# Viewer bearer (VAULT_RAG_API_TOKEN) only does reads when this is set.
# Leave unset for legacy single-token mode (logs a startup warning).
VAULT_RAG_FLEET_ADMIN_TOKEN=change-me

# ---- Grafana ----
VAULT_RAG_GRAFANA_ADMIN_PASS=change-me
VAULT_RAG_GRAFANA_PASS=change-me
VAULT_RAG_TOKMON_GRAFANA_PASS=change-me

# ---- token-monitor ----
VAULT_RAG_TOKMON_PARSER_PASS=change-me
VAULT_RAG_TOKMON_INGEST_TOKEN=change-me

# ---- Secrets vault (age-encrypted) ----
# Private age key on the host (mounted read-only into vault-rag-api as /run/secrets/age.key).
# Generated by scripts/secrets-bootstrap.sh.
# Default: /opt/vault-rag/.secrets/age.key — do NOT change unless you also update docker-compose.yml.
