# Copy to .env and fill in. Do NOT commit .env.
# `deploy.sh --bootstrap-env` will replace every `=change-me` with `openssl rand -hex 32`.

# ---- Public domain & TLS ----
# DNS A/AAAA must point at this host. Caddy will auto-issue TLS via Let's Encrypt.
VAULT_RAG_DOMAIN=vault.example.com
VAULT_RAG_ACME_EMAIL=admin@example.com

# ---- Postgres superuser ----
VAULT_RAG_PG_USER=postgres
VAULT_RAG_PG_PASSWORD=change-me

# ---- API tokens (Bearer headers) ----
VAULT_RAG_API_TOKEN=change-me
VAULT_RAG_MCP_TOKEN=change-me

# ---- Grafana ----
VAULT_RAG_GRAFANA_ADMIN_PASS=change-me
VAULT_RAG_GRAFANA_PASS=change-me
VAULT_RAG_TOKMON_GRAFANA_PASS=change-me

# ---- token-monitor ----
VAULT_RAG_TOKMON_PARSER_PASS=change-me
VAULT_RAG_TOKMON_INGEST_TOKEN=change-me

# ---- Vault git auto-sync (optional) ----
# If set, every /api/put and /api/task/* write commits the vault and pushes to
# this remote (1.5s debounce, fire-and-forget). Leave empty to disable.
# Requires SSH key at /root/.ssh/ readable to the vault-rag-api container.
# Example: ssh://git@your-forgejo-host:222/user/obsidian-vault.git
VAULT_GIT_REMOTE=
