FROM node:22-alpine

RUN apk add --no-cache git openssh-client tini ca-certificates wget age bash postgresql-client \
 && rm -rf /var/cache/apk/*

# vt-0135: the node:22-alpine image already ships a `node` user at uid/gid
# 1000 — reuse it for services that don't need to write to host bind-mounts
# (mcp, tokmon-ingest). Services that DO need write access to /vault (api,
# tools) can override `user:` in compose until /root/obsidian-vault is
# chown'd to 1000:1000 on the host (filed as vt-0137).

# I2 (audit pass 2): pin claude-code + `--ignore-scripts` so a supply-chain
# compromise can't execute arbitrary `postinstall` at image build. Bump
# intentionally; do NOT use `latest`.
RUN npm install -g --ignore-scripts @anthropic-ai/claude-code@2.1.143

ENV HOME=/root
WORKDIR /scripts

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["sleep", "infinity"]
