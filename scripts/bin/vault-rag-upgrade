#!/usr/bin/env bash
# vt-0219: one-shot upgrade pipeline for a vault-rag deployment.
#
# Sequence:
#   1. git fetch + show what's new
#   2. (optional) backup current pg + secrets via vault-rag-backup
#   3. git pull
#   4. docker compose pull  (images)
#   5. apply any new sql/*.sql migrations
#   6. docker compose up -d --no-deps vault-rag-api vault-rag-secrets
#   7. /readyz poll until 200 (or fail after timeout)
#
# Idempotent + safe: any step that can break leaves the system in the
# previous good state. Operator can re-run.
#
# Usage:
#   vault-rag-upgrade                          # backup, pull, migrate, restart
#   vault-rag-upgrade --skip-backup            # for staging / when DR'd recently
#   vault-rag-upgrade --check                  # dry-run: show plan only
#   vault-rag-upgrade --backup-to /mnt/bk.age  # custom backup destination

set -Eeuo pipefail

REPO_DIR="${VAULT_RAG_DIR:-/opt/vault-rag}"
CHECK=""
SKIP_BACKUP=""
BACKUP_TO=""
BACKUP_RECIPIENT="${VAULT_RAG_BACKUP_RECIPIENT:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check) CHECK=1; shift;;
    --skip-backup) SKIP_BACKUP=1; shift;;
    --backup-to) BACKUP_TO="$2"; shift 2;;
    --recipient) BACKUP_RECIPIENT="$2"; shift 2;;
    --repo-dir) REPO_DIR="$2"; shift 2;;
    -h|--help)
      sed -n '3,18p' "$0" | sed 's/^# \?//'
      exit 0;;
    *) echo "unknown flag: $1" >&2; exit 2;;
  esac
done

[[ -d "$REPO_DIR" ]] || { echo "repo dir not found: $REPO_DIR" >&2; exit 1; }
cd "$REPO_DIR"

log() { printf '\033[36m==>\033[0m %s\n' "$*"; }
ok()  { printf '\033[32m✓\033[0m %s\n' "$*"; }
warn(){ printf '\033[33m!\033[0m %s\n' "$*" >&2; }

# 1. fetch + show
log "fetching from origin…"
git fetch --quiet
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse '@{u}')
if [[ "$LOCAL" == "$REMOTE" ]]; then
  ok "already up-to-date at $(git log -1 --format='%h %s')"
  [[ -z "$CHECK" ]] || exit 0
fi

echo
echo "Pending commits:"
git log --oneline "$LOCAL..$REMOTE" | head -20
echo

# vt-0263: migrations are detected by diffing the on-disk sql/*.sql
# directory against the .migrations-applied sidecar. We seed the
# sidecar HERE (pre-pull) — that handles the "fresh install with DB
# already provisioned" case — but the actual NEW_MIGRATIONS list is
# collected AFTER git pull (vt-0271 fix), since the new files only
# land on disk once we've pulled the remote.
MIGRATIONS_APPLIED_FILE=".migrations-applied"
NEW_MIGRATIONS=()
# Seed the sidecar from the DB if it doesn't exist. On a brand-new host
# the rag-api boot run already ran every sql/*.sql, so they're effectively
# applied — record them as such, so the first upgrade after install does
# not try to replay 001-NNN. We detect "DB is initialised" by probing for
# vault_audit (the first table created in 001-init.sql).
if [[ ! -f "$MIGRATIONS_APPLIED_FILE" ]]; then
  if docker exec -i vault-rag-postgres psql -U postgres -d vault_rag -tAc \
       "SELECT to_regclass('vault_audit')::text" 2>/dev/null | grep -q '^vault_audit$'; then
    log "seeding $MIGRATIONS_APPLIED_FILE from existing sql/*.sql (one-time)"
    { echo "# vt-0263 sidecar — one entry per applied migration filename";
      for f in sql/*.sql; do basename "$f"; done | sort; } > "$MIGRATIONS_APPLIED_FILE"
  fi
fi
# Pre-pull pending list — informational only, the real detection
# happens post-pull below (after git pull --ff-only).
if git diff --quiet "$LOCAL..$REMOTE" -- 'sql/*.sql' 2>/dev/null; then
  : # no migration files changed between $LOCAL and $REMOTE
else
  echo "Pending migration files in the incoming commits:"
  git diff --name-only "$LOCAL..$REMOTE" -- 'sql/*.sql' 2>/dev/null | sed 's/^/  /'
  echo
fi

if [[ -n "$CHECK" ]]; then
  ok "dry-run complete (use without --check to apply)"
  exit 0
fi

# 2. backup
if [[ -z "$SKIP_BACKUP" ]]; then
  log "creating pre-upgrade backup…"
  BACKUP_TO="${BACKUP_TO:-/tmp/vault-rag-pre-upgrade-$(date +%F-%H%M).tar.age}"
  if [[ -z "$BACKUP_RECIPIENT" ]]; then
    warn "no --recipient/VAULT_RAG_BACKUP_RECIPIENT; backup will prompt for passphrase"
  fi
  BK_ARGS=(--to "$BACKUP_TO" --pg-dump)
  [[ -n "$BACKUP_RECIPIENT" ]] && BK_ARGS+=(--recipient "$BACKUP_RECIPIENT")
  if "$(dirname "$0")/vault-rag-backup" "${BK_ARGS[@]}"; then
    ok "backup → $BACKUP_TO"
  else
    warn "backup failed — aborting upgrade. Run with --skip-backup if intentional."
    exit 1
  fi
fi

# 3. git pull
log "git pull --ff-only…"
git pull --ff-only

# vt-0271: NEW_MIGRATIONS detection AFTER pull, when the new sql/*.sql
# files actually exist on disk. Previously detection ran pre-pull and
# silently missed any migration introduced by the incoming commits
# (regression hit sql/026 in commit 6eb6661).
declare -A _applied=()
if [[ -f "$MIGRATIONS_APPLIED_FILE" ]]; then
  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    _applied["$line"]=1
  done < "$MIGRATIONS_APPLIED_FILE"
fi
shopt -s nullglob
for f in sql/*.sql; do
  base=$(basename "$f")
  [[ -z "${_applied[$base]:-}" ]] && NEW_MIGRATIONS+=("$f")
done
shopt -u nullglob
if [[ ${#NEW_MIGRATIONS[@]} -gt 0 ]]; then
  IFS=$'\n' NEW_MIGRATIONS=($(sort <<<"${NEW_MIGRATIONS[*]}")); unset IFS
  echo "Migrations to apply (vs $MIGRATIONS_APPLIED_FILE):"
  printf '  %s\n' "${NEW_MIGRATIONS[@]}"
  echo
fi
ok "now at $(git log -1 --format='%h %s')"

# 4. docker compose pull (best-effort — local images may not be in a registry)
log "docker compose pull…"
docker compose pull 2>&1 | tail -10 || warn "docker compose pull had issues (local-build images expected)"

# 5a. regenerate Caddyfile from .tmpl if .tmpl changed (vt-0250).
#     Earlier prod had Caddyfile and Caddyfile.tmpl drift because no step
#     in the upgrade pipeline did envsubst. Now: if .tmpl exists AND its
#     hash differs from a sidecar marker, regenerate + reload Caddy.
if [[ -f Caddyfile.tmpl ]]; then
  TMPL_SHA=$(sha256sum Caddyfile.tmpl | cut -d' ' -f1)
  MARKER=".caddyfile.tmpl.applied.sha"
  PREV_SHA=$(cat "$MARKER" 2>/dev/null || echo none)
  if [[ "$TMPL_SHA" != "$PREV_SHA" ]]; then
    log "Caddyfile.tmpl changed → regenerating Caddyfile…"
    if [[ -f Caddyfile ]]; then
      cp Caddyfile "Caddyfile.bak.$(date +%Y%m%d-%H%M)"
    fi
    # vt-0250 hardening: source .env in a subshell so secret values don't
    # leak into the parent process env (visible via /proc/<pid>/environ).
    # envsubst's allowlist syntax substitutes ONLY the named vars; literal
    # $PATH / $HOME elsewhere in the template stay intact.
    ALLOW='${VAULT_RAG_DOMAIN} ${VAULT_RAG_ACME_EMAIL}'
    if ! ( set -a; [[ -f .env ]] && . .env; set +a; envsubst "$ALLOW" < Caddyfile.tmpl > Caddyfile.new ); then
      warn "envsubst failed — keeping previous Caddyfile."
      rm -f Caddyfile.new
    else
      # Validate before swap to avoid breaking prod with a half-substituted config.
      if docker compose exec -T vault-rag-caddy caddy validate --adapter caddyfile --config /dev/stdin < Caddyfile.new > /dev/null 2>&1; then
        mv Caddyfile.new Caddyfile
        echo "$TMPL_SHA" > "$MARKER"
        ok "Caddyfile regenerated"
        # vt-0277: prefer `caddy reload` (zero downtime) but fall back to
        # container restart when the bind-mount overlay shows a stale
        # file. Symptom: reload returns "config is unchanged" even after
        # the host file is updated (Docker overlay-fs caching of the
        # mount inode). Restart forces a fresh fopen. ~500ms downtime —
        # acceptable for structural config changes (security headers,
        # new rate-limit zones, etc.).
        log "reloading Caddy…"
        if docker compose exec -T vault-rag-caddy caddy reload --adapter caddyfile --config /etc/caddy/Caddyfile > /dev/null 2>&1; then
          ok "caddy reload returned ok — verifying header propagation"
          # Sanity probe: re-fetch / and check that one of the headers
          # we just declared is actually live. If not, fall through to
          # restart. The check uses host loopback (Caddy is in host
          # network mode) to avoid DNS dependency.
          if curl -skI -m 3 https://127.0.0.1/ 2>/dev/null | grep -qi 'x-frame-options:'; then
            ok "caddy reloaded without downtime"
          else
            warn "reload returned ok but headers did not propagate (stale-mount race) — restarting"
            docker compose restart vault-rag-caddy 2>&1 | tail -2
          fi
        else
          warn "caddy reload failed — falling back to container restart"
          docker compose restart vault-rag-caddy 2>&1 | tail -2
        fi
      else
        warn "envsubst output failed caddy validate — keeping previous Caddyfile."
        rm -f Caddyfile.new
      fi
    fi
  else
    ok "Caddyfile up-to-date (tmpl unchanged)"
  fi
fi

# 5. apply migrations
if [[ ${#NEW_MIGRATIONS[@]} -gt 0 ]]; then
  log "applying ${#NEW_MIGRATIONS[@]} migration(s)…"
  for sql in "${NEW_MIGRATIONS[@]}"; do
    echo "  -> $sql"
    if ! cat "$sql" | docker exec -i vault-rag-postgres psql -U postgres -d vault_rag -v ON_ERROR_STOP=1 > /dev/null; then
      warn "migration $sql failed — aborting before container restart."
      # vt-0246: print rollback recipe — repo has new code on disk but
      # containers still run the previous binary. Operator must roll back
      # to the recorded SHA before retrying.
      warn ""
      warn "ROLLBACK:"
      warn "  git -C $REPO_DIR reset --hard $LOCAL"
      warn "  docker compose -f $REPO_DIR/docker-compose.yml up -d --no-deps vault-rag-api vault-rag-secrets"
      exit 1
    fi
    # vt-0263: record successful migration so re-runs don't replay or skip.
    # vt-0271: explicit check — if the sidecar write fails (disk full, RO fs)
    # we'd silently leak the applied state and replay on next run.
    if ! echo "$(basename "$sql")" >> "$MIGRATIONS_APPLIED_FILE"; then
      warn "wrote migration $sql to DB but failed to update $MIGRATIONS_APPLIED_FILE"
      warn "next upgrade will attempt to re-apply $sql — abort + fix disk before re-running"
      exit 1
    fi
  done
  ok "migrations applied"
fi

# 5b. docker-compose.yml structural changes — if x-logging or another
# top-level anchor changed in this update, the --no-deps recreate of
# api+secrets in step 6 only flips those two; postgres/ollama/caddy
# retain the OLD config until they're recreated. Detect by diffing
# the file across $LOCAL..HEAD and force a full `docker compose up -d`
# (without --no-deps) when docker-compose.yml moved.
if git diff --quiet "$LOCAL..HEAD" -- docker-compose.yml; then
  log "docker-compose.yml unchanged — restarting hub only"
else
  log "docker-compose.yml changed — re-applying compose to ALL containers (config flip)"
  docker compose up -d 2>&1 | tail -8
fi

# 6. restart hub containers (preserve dependencies — postgres stays up).
# Force-recreate so Node's `require` module-cache is purged. Bind-mounted
# JS source changes are visible to fs.readFileSync immediately, but
# require() caches modules per process — without recreate, the rag-api
# process keeps serving the OLD code even though the file on disk is
# new. Symptom we hit on vt-0300 deploy: /healthz/detail was missing
# the git_sync subsystem until manual --force-recreate.
log "force-recreating vault-rag-api + vault-rag-secrets to pick up new code…"
docker compose up -d --no-deps --force-recreate vault-rag-api vault-rag-secrets 2>&1 | tail -5

# 7. readyz poll
log "waiting for /readyz…"
for i in $(seq 1 30); do
  if curl -fsS -o /dev/null -m 2 "http://localhost:5679/readyz" 2>/dev/null; then
    ok "ready after ${i}s"
    log "upgrade complete: $(git log -1 --format='%h %s')"
    exit 0
  fi
  sleep 1
done
warn "/readyz did not return 200 within 30s — check 'docker compose logs vault-rag-api'"
# vt-0294: rollback recipe — code is on disk but containers are stuck;
# operator should roll back to the recorded SHA. Note: if a migration
# was applied in this run, it's already in .migrations-applied and the
# DB. Operator must manually drop or down-migrate before re-trying.
warn ""
warn "ROLLBACK:"
warn "  git -C $REPO_DIR reset --hard $LOCAL"
warn "  docker compose -f $REPO_DIR/docker-compose.yml up -d"
warn ""
if [[ ${#NEW_MIGRATIONS[@]} -gt 0 ]]; then
  warn "WARNING: the following migrations were applied in this run BEFORE /readyz failed:"
  printf '  %s\n' "${NEW_MIGRATIONS[@]}" >&2
  warn "Either keep them (they're additive — old code typically still works) OR"
  warn "manually down-migrate + edit $MIGRATIONS_APPLIED_FILE before next upgrade."
fi
exit 1
