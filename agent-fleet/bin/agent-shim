#!/usr/bin/env bash
# vt-0334 / vt-0335: agent-fleet shim. Symlinked from ~/.local/bin/
# as claude/aider/etc. Auto-wraps invocation in a tmux session so
# fleet can attach to running CLI sessions across machines.
#
# Decisions baked in (see docs/superpowers/specs/2026-05-17-session-
# attach-via-tmux-shim-design.md v0.2):
#   - filter SELF by exact realpath, not by directory — claude lives
#     in ~/.local/bin/ on stock installs; a dir-level skip would
#     strip the real binary too (architect BLOCKING #1).
#   - POSIX-style PATH walk via colon-split (no GNU `which -a`
#     dependency; busybox/alpine daemons work).
#   - $TMUX detected → skip wrap; never double-nest tmux.
#   - tmux missing → warn once, exec direct (graceful degradation;
#     fleet attach simply unavailable on that host).
#   - FLEET_AGENT / FLEET_CWD env propagated INTO tmux session so
#     daemon discovery (vt-0336) can attribute the session via
#     `tmux show-environment`.

set -euo pipefail
AGENT="$(basename "$0")"

# Resolve own realpath so PATH walk can compare and skip it.
if command -v readlink >/dev/null 2>&1 && readlink -f "$0" >/dev/null 2>&1; then
  SELF="$(readlink -f "$0")"
elif command -v realpath >/dev/null 2>&1; then
  SELF="$(realpath "$0")"
else
  SELF="$0"
fi

# Walk $PATH, return first executable that isn't ourselves by realpath.
find_real() {
  local d candidate can_rp
  local oIFS="$IFS"
  IFS=:
  for d in $PATH; do
    candidate="$d/$AGENT"
    if [ -x "$candidate" ]; then
      if command -v readlink >/dev/null 2>&1 && readlink -f "$candidate" >/dev/null 2>&1; then
        can_rp="$(readlink -f "$candidate")"
      elif command -v realpath >/dev/null 2>&1; then
        can_rp="$(realpath "$candidate")"
      else
        can_rp="$candidate"
      fi
      if [ "$can_rp" != "$SELF" ]; then
        IFS="$oIFS"
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  done
  IFS="$oIFS"
  return 1
}

REAL="$(find_real)" || {
  printf '%s\n' "agent-shim: real $AGENT not found in PATH" >&2
  exit 127
}

# Escape hatch: NO_FLEET_SHIM=1 → exec real binary directly.
if [ "${NO_FLEET_SHIM:-0}" = "1" ]; then
  exec "$REAL" "$@"
fi

# Already inside tmux? Don't re-wrap — exec real directly.
if [ -n "${TMUX:-}" ]; then
  exec "$REAL" "$@"
fi

# Tmux missing? Warn once and exec direct.
if ! command -v tmux >/dev/null 2>&1; then
  printf '%s\n' "agent-shim: tmux not installed — running $AGENT bare (fleet attach unavailable)" >&2
  exec "$REAL" "$@"
fi

# Build a unique human-readable session name. PID at the end keeps
# names distinct even when two shims fire in the same second.
CWD_BASE="$(basename "$PWD" | tr -c '[:alnum:]_-' '_' | cut -c1-30)"
TS="$(date +%s)"
SESS="${FLEET_SESSION_LABEL:-${AGENT}-${CWD_BASE}-${TS}-$$}"

# -A: attach if session with that name already exists (idempotent).
# -e: propagate env vars into the tmux session so the daemon's
#     `tmux show-environment -t $SESS` discovers FLEET_AGENT / FLEET_CWD.
exec tmux new-session -A -s "$SESS" \
  -e "FLEET_AGENT=$AGENT" \
  -e "FLEET_CWD=$PWD" \
  -e "FLEET_TS=$TS" \
  "$REAL" "$@"
