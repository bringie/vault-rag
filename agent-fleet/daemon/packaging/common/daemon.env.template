# agent-fleet daemon configuration.
# Edit this file then `systemctl restart agent-fleet-daemon` (Linux)
# or `launchctl kickstart -k gui/$(id -u)/com.fleet.daemon` (macOS).

# Hub websocket URL — your vault-rag-api host. wss:// for TLS.
AGENT_FLEET_HUB=wss://brain.itiswednesdaymydud.es/api/fleet/ws

# Bearer token. Same value that the hub's rag-api validates.
# REQUIRED — installer prompts for this on first install.
AGENT_FLEET_TOKEN=

# Public host name. Defaults to $(hostname).
#AGENT_FLEET_HOST_NAME=

# Path to claude CLI. 'claude' (PATH lookup) is fine if it's installed.
#AGENT_FLEET_CLAUDE_BIN=claude

# Where the daemon keeps its state (PID file, session metadata, etc.).
#AGENT_FLEET_STATE_DIR=/var/lib/agent-fleet

# Comma-separated capability tags the hub can target with `--capability`.
# Example: gpu,mac,m2
#AGENT_FLEET_CAPS=
