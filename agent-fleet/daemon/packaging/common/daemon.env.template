# agent-fleet daemon configuration.
# Edit this file then `systemctl restart agent-fleet-daemon` (Linux)
# or `launchctl kickstart -k gui/$(id -u)/com.fleet.daemon` (macOS).

# Hub websocket URL — your vault-rag-api host. wss:// for TLS.
AGENT_FLEET_HUB=wss://brain.itiswednesdaymydud.es/api/fleet/ws

# Bearer token. MUST be the hub's FLEET_ADMIN_TOKEN (not the regular
# VAULT_RAG_API_TOKEN). The WS upgrade with role=daemon is gated by
# acceptWsUpgrade() which requires the admin bearer when configured.
# Using the regular API token will WS-close with code 4001
# (unauthorized) — the daemon thinks the socket is alive while the hub
# marks the host offline. (vt-0389)
# Fetch with: vt secrets get VAULT_RAG_FLEET_ADMIN_TOKEN
#
# vt-0408: diagnose this failure mode:
#   journalctl -u agent-fleet-daemon.service -n 50 | grep -E 'close|unauthorized|4001'
# Hub side (run on the brain host):
#   docker logs vault-rag-api 2>&1 | grep ws_unauthorized | tail
#
# REQUIRED — installer prompts for this on first install.
AGENT_FLEET_TOKEN=

# Public host name. Defaults to $(hostname).
#AGENT_FLEET_HOST_NAME=

# Path to claude CLI. 'claude' (PATH lookup) is fine if it's installed.
#AGENT_FLEET_CLAUDE_BIN=claude

# Where the daemon keeps its state (PID file, session metadata, etc.).
#AGENT_FLEET_STATE_DIR=/var/lib/agent-fleet

# Comma-separated capability tags the hub can target with `--capability`.
# Example: gpu,mac,m2
#AGENT_FLEET_CAPS=
