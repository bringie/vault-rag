{
  "id": 8,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "green",
                  "text": "OK"
                }
              },
              "type": "value"
            },
            {
              "options": {
                "from": 1,
                "result": {
                  "color": "red",
                  "text": "ERR"
                },
                "to": 999
              },
              "type": "range"
            },
            {
              "options": {
                "-1": {
                  "color": "yellow",
                  "text": "RUN"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "vaultrag_job_last_exit_code{job_name=\"vault-indexer\"}",
          "legendFormat": "{{status}} (exit={{value}})",
          "refId": "A"
        }
      ],
      "title": "Last vault-indexer status",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 600
              },
              {
                "color": "red",
                "value": 1800
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vaultrag_job_last_age_seconds",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        }
      ],
      "title": "Age of last run (s)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vaultrag_job_last_duration_seconds",
          "legendFormat": "{{job_name}}",
          "refId": "A"
        }
      ],
      "title": "Last duration (s)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 600
              },
              {
                "color": "red",
                "value": 1800
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "vaultrag_vault_last_sha_age_seconds",
          "refId": "A"
        }
      ],
      "title": "Vault git lag (last_sha)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vaultrag_vault_chunks",
          "refId": "A"
        }
      ],
      "title": "Vault: chunks",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vaultrag_vault_files",
          "refId": "A"
        }
      ],
      "title": "Vault: files",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "vaultrag_vault_backlinks",
          "refId": "A"
        }
      ],
      "title": "Vault: backlinks",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "id": 8,
      "options": {
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "sum(vaultrag_job_running_count) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "In-flight jobs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 9,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "vaultrag_job_runs_count",
          "legendFormat": "{{job_name}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Total runs by status (cumulative)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "unit": "ops"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 10,
      "targets": [
        {
          "expr": "rate(vaultrag_job_runs_count[5m]) * 60",
          "legendFormat": "{{job_name}} / {{status}}",
          "refId": "A"
        }
      ],
      "title": "Run rate (per minute)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "vault-rag-metrics"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "id": 11,
      "targets": [
        {
          "expr": "vaultrag_job_last_age_seconds",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "vaultrag_job_last_duration_seconds",
          "format": "table",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "vaultrag_job_last_exit_code",
          "format": "table",
          "instant": true,
          "refId": "C"
        }
      ],
      "title": "Last run per job",
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "server": true
            },
            "renameByName": {
              "Value #A": "Age (s)",
              "Value #B": "Duration (s)",
              "Value #C": "Exit code",
              "job_name": "Job",
              "status": "Status"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "vault-rag",
    "jobs"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "vault-rag Jobs",
  "uid": "vault-rag-jobs",
  "version": 1
}